    "@vitest/coverage-v8": "^4.1.5",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7",
    "jsdom": "^29.1.0",
    "mini-css-extract-plugin": "^2",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "puppeteer": "^24.42.0",
    "tailwindcss": "^4.2.2",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
