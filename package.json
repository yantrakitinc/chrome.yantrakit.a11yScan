{
  "name": "a11yscan-extension",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && npx tsx e2e/extension.e2e.ts"
  },
  "dependencies": {
    "axe-core": "^4.11"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "copy-webpack-plugin": "^12",
    "css-loader": "^7",
    "jsdom": "^29.0.1",
    "mini-css-extract-plugin": "^2",
    "puppeteer": "^24.42.0",
    "ts-loader": "^9",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "webpack": "^5",
    "webpack-cli": "^5"
  }
}
